{
  "name": "platypus-macos13",
  "version": "0.0.1",
  "dependencies": [
    {
      "name": "dcmtk"
    },
    {
      "name": "opencv4",
      "features": [
        "eigen",
        "ffmpeg",
        "highgui",
        "intrinsics",
        "jpeg",
        "png",
        "tiff"
      ]
    },
    {
      "name": "libjpeg-turbo",
      "features": [
        "jpeg8"
      ]
    },
    {
      "name": "qtbase",
      "features": [
        "widgets",
        "concurrent"
      ]
    },
    {
      "name": "qtsvg"
    },
    {
      "name": "qttools"
    }
  ]
}
