set(_platypus_bundle_name "@PLATYPUS_APP_OUTPUT_NAME@.app")
set(_platypus_app_install_root "@PLATYPUS_APP_INSTALL_ROOT@")
if(IS_ABSOLUTE "${_platypus_app_install_root}")
  set(_platypus_install_root_raw "$ENV{DESTDIR}${_platypus_app_install_root}")
else()
  set(_platypus_install_root_raw "$ENV{DESTDIR}${CMAKE_INSTALL_PREFIX}/${_platypus_app_install_root}")
endif()
set(_platypus_bundle_raw "${_platypus_install_root_raw}/${_platypus_bundle_name}")
set(_platypus_macdeployqt "@MACDEPLOYQT_EXECUTABLE@")
set(_platypus_qt_plugin_dir "@PLATYPUS_QT_PLUGIN_DIR@")
set(_platypus_qt_plugin_files "@PLATYPUS_QT_PLUGIN_FILES_JOINED@")

if(NOT EXISTS "${_platypus_bundle_raw}")
  message(FATAL_ERROR "Platypus app bundle not found for Qt deployment: ${_platypus_bundle_raw}")
endif()
get_filename_component(_platypus_bundle "${_platypus_bundle_raw}" REALPATH)
get_filename_component(_platypus_install_root "${_platypus_install_root_raw}" REALPATH)

if(NOT EXISTS "${_platypus_macdeployqt}")
  message(FATAL_ERROR "macdeployqt not found: ${_platypus_macdeployqt}")
endif()

message(STATUS "Deploying Qt frameworks into ${_platypus_bundle}")
execute_process(
  COMMAND "${_platypus_macdeployqt}" "${_platypus_bundle_name}" -no-plugins -always-overwrite
  WORKING_DIRECTORY "${_platypus_install_root}"
  RESULT_VARIABLE _platypus_macdeployqt_result
)
if(NOT _platypus_macdeployqt_result EQUAL 0)
  message(FATAL_ERROR "macdeployqt failed with exit code ${_platypus_macdeployqt_result}")
endif()

foreach(_platypus_plugin_file IN LISTS _platypus_qt_plugin_files)
  set(_platypus_plugin_source "${_platypus_qt_plugin_dir}/${_platypus_plugin_file}")
  if(EXISTS "${_platypus_plugin_source}")
    set(_platypus_plugin_destination
        "${_platypus_bundle}/Contents/PlugIns/${_platypus_plugin_file}")
    get_filename_component(_platypus_plugin_destination_dir
                           "${_platypus_plugin_destination}" DIRECTORY)
    file(MAKE_DIRECTORY "${_platypus_plugin_destination_dir}")
    file(COPY "${_platypus_plugin_source}"
         DESTINATION "${_platypus_plugin_destination_dir}")
  endif()
endforeach()
